{
  "rules": {
    ".read": false,
    ".write": false,
    "characters": {
      ".indexOn": ["owner"],
      ".read": "auth != null && query.orderByChild == 'owner' && query.equalTo == auth.uid",
      "$characterId": {
        ".read": "auth != null && data.child('owner').val() === auth.uid",
        ".write": "auth != null && ( (!data.exists() && newData.child('owner').val() === auth.uid) || (data.exists() && data.child('owner').val() === auth.uid && (!newData.exists() || newData.child('owner').val() === auth.uid)) )",
        "owner": { ".validate": "newData.isString()" },
        "updated": { ".validate": "newData.isNumber() || newData.val() == now" },
        "name": { ".validate": "newData.isString()" },
        "data": { ".validate": "newData.hasChildren()" },
        "rolls": {},
        "journal": {},
        "$other": { ".validate": false }
      }
    },
    "joinCodes": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && ( (!data.exists() && newData.isString()) || (!newData.exists() && root.child('campaigns').child(data.val()).child('meta').child('ownerUid').val() === auth.uid) )"
      }
    },
    "campaigns": {
      "$cid": {
        ".read": "auth != null && data.child('members').child(auth.uid).exists()",
        ".write": "auth != null && !newData.exists() && data.child('meta').child('ownerUid').val() === auth.uid",
        "meta": {
          ".write": "auth != null && ( (!data.exists() && newData.child('ownerUid').val() === auth.uid) || (data.exists() && data.child('ownerUid').val() === auth.uid) )",
          ".validate": "newData.hasChildren(['name','joinCode','ownerUid'])",
          "ownerUid": { ".validate": "newData.isString()" },
          "joinCode": { ".validate": "newData.isString()" },
          "name": { ".validate": "newData.isString()" },
          "createdAt": { ".validate": "newData.isNumber() || newData.val() == now" }
        },
        "members": {
          "$uid": {
            ".write": "auth != null && $uid === auth.uid",
            ".validate": "newData.hasChildren(['characterId','role'])",
            "role": { ".validate": "newData.val() === 'player' || newData.val() === 'loremaster'" }
          }
        }
      }
    }
  }
}
